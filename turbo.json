{
  "$schema": "https://turbo.build/schema.json",
  "globalPassThroughEnv": ["VIENNA_DATA_DIR", "PROFILER_PORT"],
  "tasks": {
    "dev": {
      "dependsOn": ["^build", "codegen"],
      "persistent": true,
      "cache": false
    },
    "codegen": {
      "outputs": ["src/client/generated/**", "schema.graphql"],
      "cache": false
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["out/**", ".vite/**", "dist/**", ".vitepress/dist/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "test:unit": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    },
    "test:integration": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    },
    "test:coverage": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"],
      "cache": false
    },
    "test:e2e": {
      "dependsOn": ["build"],
      "outputs": ["playwright-report/**", "test-results/**"]
    },
    "format:check": {},
    "format": {
      "cache": false
    }
  }
}
