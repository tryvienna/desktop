{
  "name": "@vienna/desktop",
  "version": "0.0.16",
  "private": true,
  "productName": "Vienna",
  "description": "Vienna desktop app",
  "license": "Apache-2.0",
  "author": "Vienna contributors",
  "homepage": "https://tryvienna.dev/docs",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tryvienna/desktop.git",
    "directory": "apps/desktop"
  },
  "bugs": {
    "url": "https://github.com/tryvienna/desktop/issues"
  },
  "main": ".vite/build/main.js",
  "scripts": {
    "dev": "electron-forge start",
    "build": "electron-forge package",
    "make": "electron-forge make",
    "make:signed": "sh -c '. ./.env.build && electron-forge make'",
    "make:staging": "VIENNA_CHANNEL=staging electron-forge make",
    "make:staging:signed": "sh -c '. ./.env.build && VIENNA_CHANNEL=staging electron-forge make'",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format:check": "prettier --check .",
    "format": "prettier --write .",
    "test": "pnpm run test:unit && pnpm run test:integration && pnpm run test:e2e",
    "test:unit": "vitest run --config vitest.config.mts unit",
    "test:integration": "vitest run --config vitest.config.mts integration",
    "test:e2e": "playwright test --config playwright.config.ts",
    "test:coverage": "vitest run --config vitest.config.mts --coverage",
    "launch": "pnpm install && pnpm run dev",
    "storybook": "storybook dev -p 6008",
    "storybook:build": "storybook build"
  },
  "dependencies": {
    "@dagrejs/dagre": "^2.0.4",
    "@json-render/core": "0.16.0",
    "@json-render/react": "0.16.0",
    "@loomhq/electron-click-through-workaround": "^0.0.1",
    "@parcel/watcher": "^2.5.1",
    "@radix-ui/react-tabs": "^1.1.13",
    "@tanstack/react-virtual": "^3.13.21",
    "@tryvienna/sdk": "workspace:*",
    "@tryvienna/ui": "workspace:*",
    "@vienna/agent-core": "workspace:*",
    "@vienna/agent-db": "workspace:*",
    "@vienna/agent-permissions": "workspace:*",
    "@vienna/agent-providers": "workspace:*",
    "@vienna/app-db": "workspace:*",
    "@vienna/chat-ui": "workspace:*",
    "@vienna/claude-session": "workspace:*",
    "@vienna/editor": "workspace:*",
    "@vienna/env": "workspace:*",
    "@vienna/file-analyzer": "workspace:*",
    "@vienna/file-search": "workspace:*",
    "@vienna/git-utils": "workspace:*",
    "@vienna/graphql": "workspace:*",
    "@vienna/ipc": "workspace:*",
    "@vienna/logger": "workspace:*",
    "@vienna/paths": "workspace:*",
    "@vienna/secure-storage": "workspace:*",
    "@vienna/shell-env": "workspace:*",
    "@vienna/whisper": "workspace:*",
    "@xyflow/react": "^12.10.1",
    "better-sqlite3": "^12.6.2",
    "cron-parser": "^5.5.0",
    "dompurify": "^3.3.3",
    "graphql": "^16.11.0",
    "lucide-react": "^0.576.0",
    "onnxruntime-node": "1.21.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.1",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@apollo/client": "^3.14.0",
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-dmg": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/plugin-fuses": "^7.11.1",
    "@electron-forge/plugin-vite": "^7.11.1",
    "@electron/fuses": "^1.8.0",
    "@electron/rebuild": "^4.0.3",
    "@eslint/js": "^9.39.3",
    "@playwright/test": "^1.58.2",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/react": "^8.6.14",
    "@storybook/react-vite": "^8.6.14",
    "@storybook/test": "^8.6.14",
    "@tailwindcss/vite": "^4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/dagre": "^0.7.54",
    "@types/dompurify": "^3.2.0",
    "@types/node": "^25.3.2",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.5.2",
    "@vitest/coverage-v8": "^4.0.18",
    "@vscode/ripgrep": "^1.17.1",
    "electron": "40.6.1",
    "esbuild": "^0.27.0",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "graphql-tag": "^2.12.6",
    "jsdom": "^28.1.0",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "storybook": "^8.6.14",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
