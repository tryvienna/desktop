{
  "name": "@vienna/chat-ui",
  "version": "0.0.1",
  "private": true,
  "description": "React chat components and Zustand store for Vienna agent UI",
  "license": "Apache-2.0",
  "author": "Vienna contributors",
  "homepage": "https://tryvienna.dev/docs",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tryvienna/desktop.git",
    "directory": "packages/chat-ui"
  },
  "bugs": {
    "url": "https://github.com/tryvienna/desktop/issues"
  },
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./store": "./src/store/index.ts",
    "./theme.css": "./src/theme/chat-ui.css"
  },
  "scripts": {
    "build": "tsc --build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
