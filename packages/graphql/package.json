{
  "name": "@vienna/graphql",
  "version": "0.0.1",
  "private": true,
  "description": "Code-first GraphQL schema (Pothos) + Apollo Client utilities for Vienna",
  "license": "Apache-2.0",
  "author": "Vienna contributors",
  "homepage": "https://tryvienna.dev/docs",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tryvienna/desktop.git",
    "directory": "packages/graphql"
  },
  "bugs": {
    "url": "https://github.com/tryvienna/desktop/issues"
  },
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts",
    "./client": "./src/client/index.ts",
    "./client/operations": "./src/client/operations.ts",
    "./client/generated/graphql": "./src/client/generated/graphql.ts"
  },
  "scripts": {
    "build": "tsc --build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format:check": "prettier --check .",
    "format": "prettier --write .",
    "test": "pnpm run test:unit",
    "test:unit": "vitest run",
    "test:coverage": "vitest run --coverage",
    "schema:print": "tsx src/schema/print.ts",
    "codegen": "tsx src/schema/print.ts --write && graphql-codegen --config codegen.ts"
  },
  "dependencies": {
    "@apollo/client": "^3.13.8",
    "@pothos/core": "^4.6.0",
    "@vienna/app-db": "workspace:*",
    "@tryvienna/sdk": "workspace:*",
    "graphql": "^16.11.0",
    "graphql-tag": "^2.12.6"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@eslint/js": "^9.39.3",
    "@graphql-codegen/cli": "^6.1.2",
    "@graphql-codegen/client-preset": "^5.2.3",
    "@graphql-typed-document-node/core": "^3.2.0",
    "@types/node": "^25.3.2",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "tsx": "^4.20.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  }
}
