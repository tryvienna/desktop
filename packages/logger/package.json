{
  "name": "@vienna/logger",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Structured logging for Vienna — main process (Pino) and renderer (IPC)",
  "license": "Apache-2.0",
  "author": "Vienna contributors",
  "homepage": "https://tryvienna.dev/docs",
  "repository": {
    "type": "git",
